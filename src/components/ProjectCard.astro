---
import type { CollectionEntry } from 'astro:content';
import TagChips from './TagChips.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const { data, id: slug } = project;

const filterTags = [
  data.category.toLowerCase().replace(/\s+/g, '-'),
  data.status.toLowerCase().replace(/\s+/g, '-'),
  ...data.tags.map((t: string) => t.toLowerCase().replace(/\s+/g, '-')),
].join(' ');

const classes = [
  'project-card',
  `project-card--${data.tone}`,
  compact ? 'project-card--compact' : '',
].filter(Boolean).join(' ');

const metrics = compact ? data.metrics.slice(0, 2) : data.metrics;
---
<article class={classes} data-reveal data-filter-item data-filter-tags={filterTags}>
  <div class="card-kicker">
    <span>{data.category}</span>
    <span>{data.status}</span>
  </div>
  <h3 class="project-card__title">
    <a href={`/projects/${slug}/`}>{data.title}</a>
  </h3>
  {data.subtitle && <p class="project-card__subtitle">{data.subtitle}</p>}
  <p class="project-card__summary">{data.summary}</p>
  <div class="chip-row">
    <TagChips tags={data.tags.slice(0, 4)} />
  </div>
  {metrics.length > 0 && (
    <div class="metric-strip">
      {metrics.map((m: { value: string; label: string }) => (
        <div class="metric-item">
          <span class="metric-item__value">{m.value}</span>
          <span class="metric-item__label">{m.label}</span>
        </div>
      ))}
    </div>
  )}
  {Object.entries(data.links).filter(([, url]) => url).length > 0 && (
    <div class="card-actions">
      {Object.entries(data.links).filter(([, url]) => url).map(([key, url]) => (
        <a
          class="button button--ghost button--compact"
          href={url as string}
          target="_blank"
          rel="noreferrer"
        >{key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}</a>
      ))}
    </div>
  )}
</article>
