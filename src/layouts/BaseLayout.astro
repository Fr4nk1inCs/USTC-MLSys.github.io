---
import { site } from '../data/site.ts';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/styles.css';

interface Props {
  title: string;
  description?: string;
  currentSection?: string;
  pageKind?: string;
}

const { title, description, currentSection = 'home', pageKind = 'page' } = Astro.props;
const pageTitle = title === site.labName ? site.labName : `${title} | ${site.labName}`;
const metaDescription = description || site.description;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="theme-color" content="#121417" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <script>document.documentElement.classList.add('js');</script>
  </head>
  <body class={`page page--${pageKind}`}>
    <div class="page-glow page-glow--teal" aria-hidden="true"></div>
    <div class="page-glow page-glow--copper" aria-hidden="true"></div>
    <SiteNav currentSection={currentSection} />
    <main class="site-main">
      <slot />
    </main>
    <SiteFooter />
    <script defer src="/assets/js/site.js"></script>
  </body>
</html>
